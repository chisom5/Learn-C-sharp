{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Error",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/app-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "PostgreSQL": {
    "ConnectionString": ""
  },
  "JwtSettings": {
    "issuer": "PolarisEclBackend",
    "Audience": "polaris-ecl",
    "Secret": "",
    "ExpiryInMinutes": 60,
    "RefreshTokenValidityInDays": 7
  },
  "AllowedHosts": "*"
}
