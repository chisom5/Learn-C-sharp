# macOS
.DS_Store

# Ignore all user calculation uploads
**/FileStorage/Uploads/*
!**/FileStorage/Uploads/.gitkeep

# Ignore everything in Templates (including admin-uploaded dynamic templates)
**/FileStorage/Templates/*

# Keep ONLY the baseline clean templates and the .gitkeep placeholder
!**/FileStorage/Templates/.gitkeep
!**/ASP.Net/PolarisEcl/API/FileStorage/Templates/PD_Data_Pool_Excel_Input.xlsx
!**/ASP.Net/PolarisEcl/API/FileStorage/Templates/Macro_Model_Historical_Forecasted_Data.xlsx